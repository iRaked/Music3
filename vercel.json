{
  "version": 2,
  "cleanUrls": true,
  "public": true,
  "rewrites": [
    { "source": "/assets/(.*)", "destination": "/assets/$1" }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Content-Type", "value": "audio/mpeg" },
        { "key": "Access-Control-Allow-Origin", "value": "*" }
      ]
    }
  ]
}